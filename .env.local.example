# StemSplit Environment Configuration
# Copy this to .env.local and fill in your actual values

# ===== License & Stripe Configuration =====
# Gumroad product page used by the in-app sales modal
NEXT_PUBLIC_GUMROAD_PRODUCT_URL=https://gumroad.com/l/stemsplit

# Stripe Checkout URL - Get from your Stripe account
# Format: https://checkout.stripe.com/pay/cs_live_XXXXXX
NEXT_PUBLIC_STRIPE_CHECKOUT_URL=https://checkout.stripe.com/pay/your-stripe-link

# Stripe Price IDs (from Stripe Dashboard)
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_1234567890abcdef
NEXT_PUBLIC_STRIPE_PRICE_ENTERPRISE=price_0987654321fedcba

# Stripe Secret Key (server-side only, NEVER expose to frontend)
STRIPE_SECRET_KEY=sk_live_your_secret_key

# ===== Webhook Configuration =====
# Stripe Webhook Signing Secret (from Stripe Dashboard)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Gumroad ping URL secret. Recommended: append ?secret=... to your Gumroad webhook URL.
GUMROAD_WEBHOOK_SECRET=your_gumroad_webhook_secret

# Admin token for protected billing service endpoints (/api/licenses/issue, /api/licenses/admin/list)
BILLING_ADMIN_TOKEN=replace_with_a_long_random_token

# Optional: replay defense retention for processed webhook events
# MAX_TRACKED_WEBHOOK_EVENTS=20000

# Optional: Stripe signature timestamp tolerance (seconds)
# STRIPE_SIGNATURE_TOLERANCE_SEC=300

# ===== License Server =====
# Public frontend hint for hosted license service
# NEXT_PUBLIC_LICENSE_API_URL=https://billing.yourdomain.com

# Desktop app server lookup URL for remote access credentials
STEMSPLIT_LICENSE_SERVER_URL=https://billing.yourdomain.com

# Optional billing service data file override
# BILLING_DB_PATH=./billing-service/data/licenses.json

# Onboarding email provider
# RESEND_API_KEY=re_xxxxx
# STEMSPLIT_ONBOARDING_FROM=StemSplit <welcome@yourdomain.com>

# ===== Analytics =====
# Optional: Enable license event analytics
# NEXT_PUBLIC_ANALYTICS_ENABLED=true

# ===== Support Contact =====
# Support email for license-related questions
NEXT_PUBLIC_SUPPORT_EMAIL=support@stemsplit.com

# ===== Python Configuration =====
# Path to Python interpreter for separator_engine.py
PYTHON_PATH=python3

# Path to hardware_brain.py
HARDWARE_BRAIN_PATH=./hardware_brain.py

# Path to separator_engine.py
SEPARATOR_ENGINE_PATH=./separator_engine.py

# ===== Feature Flags =====
# Enable/disable demo mode (allows testing without valid license)
NEXT_PUBLIC_DEMO_MODE=false

# Enable/disable license enforcement
NEXT_PUBLIC_ENFORCE_LICENSE=true

# Demo license key (only used if DEMO_MODE=true)
NEXT_PUBLIC_DEMO_LICENSE_KEY=STEM-DEMO-0000-0000-DEMO
