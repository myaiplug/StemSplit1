{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:3000",
    "distDir": "../out"
  },
  "package": {
    "productName": "StemSplit",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "shell": {
        "open": true
      },
      "fs": {
        "all": true,
        "scope": ["**"]
      },
      "dialog": {
        "open": true,
        "save": true
      },
      "window": {
        "all": true
      },
      "protocol": {
        "asset": true,
        "assetScope": ["**"]
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.stemsplit.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "resources": [
        "../python_env",
        "../drumsep-main/model",
        "../MVSEP-MDX23-music-separation-model-main/models",
        "../Stem Split Models",
        "../UVR",
        "../scripts"
      ],
      "macOS": {
        "frameworks": [],
        "minimumSystemVersion": "10.13",
        "exceptionDomain": "",
        "signing": {
          "identity": null,
          "entitlements": null
        },
        "providerShortName": null,
        "signingIdentity": null,
        "hardenedRuntime": true,
        "entitlements": "../entitlements.plist"
      },
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": true
      },
      "dmg": {
        "background": "../dmg-background.png",
        "window": {
          "width": 600,
          "height": 400
        },
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 420,
          "y": 170
        }
      }
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 1200,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "title": "StemSplit v1.2 - NoDAW Studio",
        "width": 640,
        "minHeight": 700,
        "minWidth": 420
      }
    ]
  }
}
